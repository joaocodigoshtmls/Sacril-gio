generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  sessions      Session[]
  detections    Detection[]
}

model Camera {
  id            String    @id @default(cuid())
  name          String
  type          CameraType
  url           String
  status        CameraStatus @default(INACTIVE)
  recordings    Recording[]
  detections    Detection[]
}

model Recording {
  id            String    @id @default(cuid())
  cameraId      String
  camera        Camera    @relation(fields: [cameraId], references: [id])
  startTime     DateTime  @default(now())
  endTime       DateTime?
  fileUrl       String?
  metadata      Json?
}

model Detection {
  id            String    @id @default(cuid())
  cameraId      String
  camera        Camera    @relation(fields: [cameraId], references: [id])
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  confidence    Float
  timestamp     DateTime  @default(now())
  metadata      Json
}

model Session {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  expires       DateTime
  sessionToken  String    @unique
  accessToken   String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum CameraType {
  ESP32
  HLS
  RTSP
}

enum CameraStatus {
  ACTIVE
  INACTIVE
  ERROR
}
